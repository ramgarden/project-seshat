<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ProjectSeshat.App.MainWindow"
        Width="1120"
        Height="720"
        MinWidth="840"
        MinHeight="560"
        Background="#08111D"
        Title="{Binding WindowTitle}">
  <Window.Styles>
    <Style Selector="Border.stat-card">
      <Setter Property="Background" Value="#0E1D2E" />
      <Setter Property="BorderBrush" Value="#1A4D67" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="22" />
    </Style>
    <Style Selector="TextBlock.section-label">
      <Setter Property="Foreground" Value="#7DAAC4" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="LetterSpacing" Value="1.4" />
    </Style>
  </Window.Styles>

  <Grid Margin="48" RowDefinitions="Auto,*,Auto">
    <StackPanel Spacing="8">
      <TextBlock Text="{Binding ProjectName}"
                 FontSize="34"
                 FontWeight="Bold"
                 Foreground="#E5F5FF"
                 LetterSpacing="2" />
      <TextBlock Text="{Binding PlatformName}"
                 FontSize="17"
                 Foreground="#83B8D5" />
      <Border Height="2" Width="96" Margin="0,16,0,0" HorizontalAlignment="Left" Background="#36C5F0" />
    </StackPanel>

    <StackPanel Grid.Row="1" Margin="0,58,0,0" Spacing="18">
      <TextBlock Classes="section-label" Text="{Binding StatisticsHeading}" />
      <Grid ColumnDefinitions="*,18,*,18,*">
        <Border Classes="stat-card" Grid.Column="0">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-label" Text="{Binding SystemsIndexedLabel}" />
            <TextBlock Text="{Binding SystemsIndexedCount}" FontSize="36" FontWeight="Light" Foreground="#E5F5FF" />
          </StackPanel>
        </Border>
        <Border Classes="stat-card" Grid.Column="2">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-label" Text="{Binding CommanderRecordsLabel}" />
            <TextBlock Text="{Binding CommanderRecordsCount}" FontSize="36" FontWeight="Light" Foreground="#E5F5FF" />
          </StackPanel>
        </Border>
        <Border Classes="stat-card" Grid.Column="4">
          <StackPanel Spacing="10">
            <TextBlock Classes="section-label" Text="{Binding EvidenceRecordsLabel}" />
            <TextBlock Text="{Binding EvidenceRecordsCount}" FontSize="36" FontWeight="Light" Foreground="#E5F5FF" />
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>

    <Border Grid.Row="2" Background="#0E1D2E" BorderBrush="#1A4D67" BorderThickness="1" CornerRadius="6" Padding="18">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <Ellipse Width="10" Height="10" Fill="#36C5F0" VerticalAlignment="Center" />
        <TextBlock Text="{Binding StatusMessage}" Foreground="#D2EAF7" FontSize="15" VerticalAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
